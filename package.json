{
  "name": "plushelter",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "demo:on": "node scripts/set-demo-mode.mjs true",
    "demo:off": "node scripts/set-demo-mode.mjs false",
    "serve:ssr:plushelter": "node dist/plushelter/server/server.mjs",
    "experiment:build": "tsc -p tsconfig.external-agent.json && cp external-agent/package.json dist/external-agent/package.json",
    "experiment:start": "node --env-file=.env dist/external-agent/scripts/experiment.js",
    "external-agent:build": "npm run experiment:build",
    "external-agent": "npm run external-agent:agent",
    "external-agent:agent": "GEMINI_API_KEY=$(netlify env:get GEMINI_API_KEY --context dev) npx adk run external-agent/agent.ts",
    "external-agent:web": "GEMINI_API_KEY=$(netlify env:get GEMINI_API_KEY --context dev) npx adk web external-agent"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/aria": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-server": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/ssr": "^22.0.7",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/karla": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@google/adk": "1.4.0",
    "@google/genai": "^1.14.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@google/adk-devtools": "1.4.0",
    "@netlify/angular-runtime": "^4.0.0",
    "@netlify/functions": "^5.3.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "istanbul-lib-instrument": "^6.0.3",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.3.0",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
